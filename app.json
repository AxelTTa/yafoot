{
  "expo": {
    "name": "YaFoot",
    "slug": "yafoot",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "yafoot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1B3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.axelcassou.yafoot",
      "buildNumber": "6",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Choose a profile photo for your YaFoot account",
        "NSCameraUsageDescription": "Take a profile photo for your YaFoot account"
      }
    },
    "android": {
      "package": "com.yafoot.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A1B3D"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Ionicons.ttf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "YaFoot uses your photos to set your profile picture."
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "https://zfsgclwyaapgwxjtzvyd.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inpmc2djbHd5YWFwZ3d4anR6dnlkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE3MjE5OTcsImV4cCI6MjA5NzI5Nzk5N30.t4UyTSN6N0wCcrIdLcH1Nj9oVw7S0XcQ5sNYVKMedtc",
      "appStoreSafe": false,
      "eas": {
        "projectId": "cdd9d91b-7eb4-4e0f-9812-da13924138bd"
      }
    },
    "owner": "axelttas-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/cdd9d91b-7eb4-4e0f-9812-da13924138bd"
    }
  }
}
